# PostgreSQL connection used by the app at runtime.
# Locally: matches docker-compose.yml. On Neon: use the POOLED connection string.
DATABASE_URL="postgresql://palic:palic@localhost:5433/palic_quiz?schema=public"

# Direct (non-pooled) connection used by `prisma migrate`.
# Locally: same as DATABASE_URL. On Neon: use the DIRECT connection string.
DIRECT_URL="postgresql://palic:palic@localhost:5433/palic_quiz?schema=public"

# Admin panel login password
ADMIN_PASSWORD="change-me"

# Secret used to sign the admin session cookie.
# REQUIRED in production (the app refuses to start without a strong value).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-to-a-long-random-string"

# When "true", the location/geofence check is skipped entirely (useful for testing
# off-site). Keep "false" for the real on-site event.
NEXT_PUBLIC_DISABLE_GEOFENCE="false"
